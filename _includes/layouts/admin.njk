{% extends "layouts/base.njk" %}

{% block extra_nav %}
<li class="nav-item admin-only" id="install-item" style="display: none;"><button id="install-button" class="btn">Install</button></li>
{% endblock %}

{% block head %}
<script type="importmap" eleventy:ignore>
{
  "imports": {
    "prompt-api-polyfill": "{{ '/assets/js/prompt-api-polyfill/prompt-api-polyfill.js' | url }}",
    "built-in-ai-task-apis-polyfills/": "{{ '/assets/js/built-in-ai-task-apis-polyfills/' | url }}",

    "firebase/app": "{{ '/assets/js/firebase/firebase-app.js' | url }}",
    "firebase/ai": "{{ '/assets/js/firebase/firebase-ai.js' | url }}",
    "https://www.gstatic.com/firebasejs/12.10.0/firebase-app.js": "{{ '/assets/js/firebase/firebase-app.js' | url }}",

    "browser-fs-access": "{{ '/assets/js/browser-fs-access/index.modern.js' | url }}",

    "@google/genai": "{{ '/assets/js/google-genai/index.mjs' | url }}",
    "openai": "{{ '/assets/js/openai/index.mjs' | url }}",
    "@huggingface/transformers": "{{ '/assets/js/huggingface-transformers/transformers.web.js' | url }}",
    "onnxruntime-web/webgpu": "{{ '/assets/js/onnxruntime-web/ort.webgpu.mjs' | url }}",
    "onnxruntime-common": "{{ '/assets/js/onnxruntime-common/index.js' | url }}",

    "p-retry": "{{ '/assets/js/helpers/p-retry-esm.js' | url }}",
    "dompurify": "{{ '/assets/js/dompurify/purify.es.mjs' | url }}"
  }
}
</script>

<style eleventy:ignore>
  @keyframes hideBriefly {
    0%,
    100% {
      visibility: hidden;
    }
  }

  label:has(input[switch]),
  input[switch] {
    animation: hideBriefly 2s;
  }
</style>

<noscript>
  <style eleventy:ignore>
    label:has(input[switch]),
    input[switch] {
      animation: none;
    }
  </style>
</noscript>

<script type="module" eleventy:ignore>
  if (!('switch' in HTMLInputElement.prototype)) {
    const css = document.createElement('link');
    css.rel = 'stylesheet';
    css.href = '{{ '/assets/js/input-switch-polyfill/input-switch-polyfill.css' | url }}';
    document.head.append(css);

    await import('{{ '/assets/js/input-switch-polyfill/input-switch-polyfill.js' | url }}');
  } else {
    document.head.insertAdjacentHTML(
      'beforeend',
      `<style>label:has(input[switch]),input[switch]{animation:none;}</style>`
    );
  }
</script>

<link rel="stylesheet" href="/assets/css/create-post.css">
<link rel="stylesheet" href="/assets/js/prismjs/themes/prism-okaidia.css">
<link rel="manifest" href="/{{ metadata.language }}/blog/admin/manifest.json">

<script src="/assets/js/marked/marked.umd.js"></script>
<script src="/assets/js/prismjs/prism.js"></script>
<script src="/assets/js/turndown/turndown.js"></script>
<script src="/assets/js/jszip/jszip.js"></script>

<script type="module" src="/assets/js/editor/create-post.js" eleventy:ignore></script>

<script eleventy:ignore>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('{{ ('/' + metadata.language + '/blog/admin/sw.js') | url }}', { scope: '{{ ('/' + metadata.language + '/blog/admin/') | url }}' });
    });
  }

  (async () => {
    if (
      ('storage' in navigator && 'persist' in navigator.storage) &&
      (matchMedia('(display-mode: standalone)').matches || navigator.standalone)
    ) {
      const persisted = await navigator.storage.persist();
      console.log(`Storage persisted: ${persisted}`);
    }
  })();

  let deferredPrompt;

  window.addEventListener('beforeinstallprompt', (e) => {    
    e.preventDefault();
    deferredPrompt = e;
    const item = document.getElementById('install-item');
    if (item) {
      item.style.display = 'initial';
    }
  });

  window.addEventListener('DOMContentLoaded', () => {
    const installBtn = document.getElementById('install-button');
    if (installBtn) {
      installBtn.addEventListener('click', async () => {
        if (!deferredPrompt) return;
        deferredPrompt.prompt();
        const { outcome } = await deferredPrompt.userChoice;
        if (outcome === 'accepted') {
          deferredPrompt = null;
          const item = document.getElementById('install-item');
          if (item) item.style.display = 'none';
        }
      });
    }

    window.addEventListener('appinstalled', async () => {
      const item = document.getElementById('install-item');
      if (item) {
        item.style.display = 'none';
      }
      if ('storage' in navigator && 'persist' in navigator.storage) {
        const persisted = await navigator.storage.persist();
        console.log(`Storage persisted: ${persisted}`);
      }
    });
  });
</script>
{% endblock %}
